rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // =========================================================================
    // SYSTEM: CIPHER PROTECTION PROTOCOLS v3 (Security Hardened)
    // STATUS: ACTIVE
    // =========================================================================

    // HELPER FUNCTIONS
    
    // Check if the authenticated user's ID matches the requested target
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Check if the user has an elevated role (manager, owner, admin, superadmin)
    function isSystemAdmin() {
      // NOTE: We now use systemRole for global platform administration.
      let systemRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.systemRole;
      return request.auth != null && (systemRole == 'admin' || systemRole == 'superadmin');
    }

    // Backwards-compatible alias for legacy rules relying on global staff override
    function isManager() {
      return isSystemAdmin();
    }
    function isSuperAdmin() {
      let systemRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.systemRole;
      return request.auth != null && systemRole == 'superadmin';
    }

    // Allow authenticated users to interact seamlessly with public feed posts
    function isInteractionUpdate() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['commentCount', 'latestComment', 'interestedUserIds', 'reactionUserIds', 'attendeeIds', 'reactions']);
    }

    // =========================================================================
    // COLLECTIONS
    // =========================================================================

    // 1. PUBLIC PROFILES (For Safe Search)
    // Policy: Public Read, Owner Write (Sanitized fields only logic handled by client, 
    // but we can enforce some basics here if needed, or rely on the Fact that 
    // sensitive fields aren't even IN this collection).
    match /public_profiles/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // 2. USERS COLLECTION
    // Policy: Owner Read. Owner Update (Restricted Fields).
    match /users/{userId} {
      allow read: if isOwner(userId);
      
      // Create: Allow initial creation.
      allow create: if isOwner(userId);

      // Update: Prevent changing 'systemRole', 'role', 'currentPoints', or 'qrToken'
      // effectively locking the "sensitive" fields.
      allow update: if isOwner(userId) 
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['systemRole', 'role', 'currentPoints', 'qrToken']));
                    
      // Subcollections
      match /memberships/{hallId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) || isManager(); 
      }
      match /friends/{friendId} {
        allow read: if request.auth != null;
        allow write: if isOwner(userId) || isManager() || (request.auth != null && friendId == request.auth.uid);
      }
      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) || isManager(); 
      }
      match /raffle_tickets/{ticketId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) || isManager(); 
      }
      match /tournaments/{tournamentId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) || isManager(); 
      }
      match /my_items/{itemId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) || isManager(); 
      }
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow create: if request.auth != null;
        allow update, delete: if isOwner(userId) || isManager() || (request.auth != null && notificationId == 'friend_req_' + request.auth.uid); 
      }
    }

    // 2.5. PUBLIC WORKERS (For Verification)
    // Policy: Authenticated users can READ. Only Managers can WRITE.
    match /public_workers/{workerId} {
      allow read: if request.auth != null;
      allow write: if isManager();
    }

    // 3. BINGO HALLS COLLECTION
    // Policy: Public Read, Manager Write.
    match /bingo_halls/{hallId} {
      allow read: if true;
      allow write: if isManager();
      
      // Tournaments Subcollection
      match /tournaments/{tournamentId} {
        allow read: if true;
        allow write: if isManager();
      }

      // Store Items Subcollection
      match /store_items/{itemId} {
        allow read: if true;
        allow write: if isSystemAdmin();
      }
      
      // Team Members Subcollection (Multi-Entity Switcher RBAC)
      match /team/{userId} {
        allow read: if true;
        allow write: if isSystemAdmin();
      }
    }
    
    // 3.5. VENUES (Alias for BINGO HALLS in new RBAC)
    match /venues/{venueId} {
      allow read: if true;
      allow write: if isSystemAdmin();
      
      match /team/{userId} {
        allow read: if true;
        allow write: if isSystemAdmin();
      }
    }

    // 4. TRANSACTIONS COLLECTION
    // Policy: User Read Own, Manager Read All, Append-Only (No Delete).
    match /transactions/{transactionId} {
      // Create: Authenticated users can create, but MUST claim the transaction as their own.
      allow create: if request.auth != null && 
                       request.resource.data.userId == request.auth.uid;
      
      // Read: Users see their own; Managers see everything.
      allow read: if (request.auth != null && resource.data.userId == request.auth.uid) || 
                     isManager();
      
      // Update/Delete: DENIED. Ledger integrity must be maintained.
      allow update, delete: if false;
    }

    // 5. RAFFLES & SPECIALS (And Root Tournaments)
    // Policy: Public Read, Manager Write, Auth User Interaction
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow update: if request.auth != null && isInteractionUpdate();
      allow write: if isManager();
    }
    match /raffles/{raffleId} {
      allow read: if true;
      allow update: if request.auth != null && isInteractionUpdate();
      allow write: if isManager();
    }
    match /specials/{specialId} {
      allow read: if true;
      allow update: if request.auth != null && isInteractionUpdate();
      allow write: if isManager();
    }

    // 6. GALLERY PHOTOS
    match /gallery_photos/{photoId} {
      // Anyone can read photos (filtering logic is in the query)
      allow read: if true;
      
      // Any authenticated user can upload their own photo
      allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
      
      // Any auth'd user can update (to increment 'reportCount'), Managers can approve/decline
      allow update: if request.auth != null; 
      
      // Only the uploader or a manager can delete the photo
      allow delete: if request.auth != null && (resource.data.uploaderId == request.auth.uid || isManager());
    }

    // 7. COLLECTION GROUP QUERIES AND SUPER ADMIN COLLECTIONS
    match /{path=**}/tournaments/{tournamentId} {
      allow read: if true;
    }
    
    match /{path=**}/team/{userId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isSystemAdmin());
    }
    
    match /venue_claims/{claimId} {
      allow read, write: if isSystemAdmin();
      allow create: if request.auth != null;
    }

    // 8. CHATS & MESSAGES
    match /chats/{chatId} {
      // User can create a chat if they are in the participant list
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;
      // User can read or update a chat if they are in the participant list
      allow read, update: if request.auth != null && request.auth.uid in resource.data.participantIds;
      
      match /messages/{messageId} {
        // User can read or send messages in a chat if they are a participant
        allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
      }
    }

    // 9. REPORTS
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read: if isManager();
    }

    // 10. USER GENERATED CONTENT
    match /win_posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isManager();
    }
    
    match /check_ins/{checkInId} {
      allow read: if true;
      allow update: if request.auth != null && isInteractionUpdate();
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId) || isManager();
    }
    
    match /text_posts/{postId} {
      allow read: if true;
      allow update: if request.auth != null && isInteractionUpdate();
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId) || isManager();
    }

    // 11. GLOBAL COMMENTS SUBCOLLECTIONS
    match /{path=**}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow update: if isOwner(resource.data.authorId) || isManager() || (request.auth != null && isInteractionUpdate());
      allow delete: if isOwner(resource.data.authorId) || isManager();
    }
  }
}
